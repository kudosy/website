  <style>
    /* ─── RESET ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    /* ─── DESIGN TOKENS — extracted from Kudosy iOS codebase ─── */
    :root {
      /* Core iOS system colors from code */
      --app-blue:    #1C7BE3;   /* iOS .blue → SplashBGColor-adjacent, used on cards */
      --app-green:   #25B84A;   /* iOS .green — Sign In buttons, progress bars, FAB */
      --app-green-dark: #1A9438;
      --app-purple:  #A855F7;   /* Card stack back layer */
      --app-orange:  #F97316;   /* Card stack middle layer */
      --app-yellow:  #F5C842;   /* GOAL badge, coin icon */
      --app-brown:   #7C4A1E;   /* GOAL text, congrats text */

      /* Backgrounds — app uses white */
      --bg-white:    #FFFFFF;
      --bg-light:    #F5F5F5;   /* lightGray colorset: 0.96,0.96,0.96 */
      --bg-gray:     #D3D3D3;   /* BackgroundGray colorset */

      /* Text */
      --text-primary:   #1C1C1E;  /* iOS label */
      --text-secondary: #6D6D72;  /* iOS secondaryLabel */
      --text-tertiary:  #AEAEB2;

      /* Shadows — from code: .shadow(color:.black.opacity(0.3-0.7), radius:5-12) */
      --shadow-card: 0 8px 24px rgba(0,0,0,0.12), 0 2px 6px rgba(0,0,0,0.08);
      --shadow-strong: 0 12px 40px rgba(0,0,0,0.18), -5px 5px 0 rgba(0,0,0,0.08);
      --shadow-btn: 0 4px 14px rgba(37,184,74,0.4);

      /* Radii — app uses cornerRadius(20) everywhere */
      --radius: 20px;
      --radius-sm: 12px;
      --radius-xs: 8px;
      --radius-pill: 100px;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'SF Pro Display', sans-serif;
      background: var(--bg-white);
      color: var(--text-primary);
      overflow-x: hidden;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── TYPOGRAPHY — mirrors iOS .system(size:, weight:) ─── */
    h1,h2,h3,h4 { font-family: 'Inter', -apple-system, sans-serif; line-height: 1.15; letter-spacing: -0.02em; }

    .title-xl  { font-size: clamp(40px,6vw,80px);  font-weight: 800; letter-spacing: -0.03em; }
    .title-lg  { font-size: clamp(32px,4.5vw,60px); font-weight: 800; letter-spacing: -0.025em; }
    .title-md  { font-size: clamp(24px,3vw,40px);  font-weight: 700; letter-spacing: -0.02em; }
    .title-sm  { font-size: clamp(18px,2.2vw,26px); font-weight: 700; }
    .body-lg   { font-size: clamp(16px,1.6vw,19px); line-height: 1.65; font-weight: 400; }
    .body-md   { font-size: 15px; line-height: 1.6; }
    .label     { font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; }

    /* ─── LAYOUT ─── */
    .container { max-width: 1160px; margin: 0 auto; padding: 0 24px; }
    section { padding: 96px 0; }

    /* ─── COLORS ─── */
    .blue    { color: var(--app-blue); }
    .green   { color: var(--app-green); }
    .orange  { color: var(--app-orange); }
    .yellow  { color: var(--app-yellow); }
    .muted   { color: var(--text-secondary); }
    .bg-blue   { background: var(--app-blue); }
    .bg-green  { background: var(--app-green); }
    .bg-light  { background: var(--bg-light); }

    /* ─── BUTTONS — mirrors iOS .fill(.green) rounded rectangle ─── */
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 14px 28px; border-radius: var(--radius-pill);
      font-weight: 700; font-size: 16px; font-family: inherit;
      text-decoration: none; cursor: pointer; border: none;
      transition: transform 0.18s, box-shadow 0.18s;
      letter-spacing: -0.01em; white-space: nowrap;
    }
    .btn:hover  { transform: translateY(-2px); }
    .btn:active { transform: translateY(0); }

    .btn-green {
      background: var(--app-green); color: white;
      box-shadow: var(--shadow-btn);
    }
    .btn-green:hover { box-shadow: 0 8px 28px rgba(37,184,74,0.55); background: var(--app-green-dark); }

    .btn-blue {
      background: var(--app-blue); color: white;
      box-shadow: 0 4px 14px rgba(28,123,227,0.4);
    }

    .btn-white {
      background: white; color: var(--text-primary);
      box-shadow: var(--shadow-card);
      border: 1px solid rgba(0,0,0,0.06);
    }

    .btn-outline {
      background: transparent; color: var(--app-blue);
      border: 2px solid var(--app-blue);
    }

    .btn-lg { padding: 18px 40px; font-size: 18px; }

    /* Apple badge */
    .apple-badge {
      display: inline-flex; align-items: center; gap: 12px;
      background: #000; color: #fff;
      padding: 14px 28px; border-radius: 14px;
      font-weight: 700; text-decoration: none;
      transition: transform 0.18s, opacity 0.18s;
    }
    .apple-badge:hover { transform: translateY(-2px); opacity: 0.9; }
    .apple-badge .apple-icon { font-size: 26px; }
    .apple-badge-text-top { font-size: 10px; font-weight: 400; opacity: 0.7; display: block; }
    .apple-badge-text-main { font-size: 17px; font-weight: 700; display: block; }

    /* ─── NAV ─── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 999;
      padding: 14px 0;
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(20px) saturate(180%);
      -webkit-backdrop-filter: blur(20px) saturate(180%);
      border-bottom: 1px solid rgba(0,0,0,0.06);
    }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
      max-width: 1160px; margin: 0 auto; padding: 0 24px;
    }
    .nav-logo {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none; color: var(--text-primary);
    }
    .nav-logo img { width: 34px; height: 34px; border-radius: 8px; }
    .nav-logo-text {
      font-weight: 800; font-size: 20px; letter-spacing: -0.02em; color: var(--text-primary);
    }
    .nav-links { display: flex; align-items: center; gap: 28px; list-style: none; }
    .nav-links a {
      color: var(--text-secondary); text-decoration: none;
      font-weight: 500; font-size: 15px; transition: color 0.15s;
    }
    .nav-links a:hover { color: var(--text-primary); }
    @media(max-width:768px) { .nav-links { display: none; } }

    /* ─── HERO ─── */
    #hero {
      padding-top: 100px; padding-bottom: 60px;
      background: linear-gradient(180deg, #F0F8FF 0%, #FFFFFF 100%);
      overflow: hidden; position: relative;
    }
    .hero-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 60px; align-items: center;
    }
    @media(max-width:900px) {
      .hero-grid { grid-template-columns: 1fr; text-align: center; }
      .hero-right { display: none; }
      .hero-actions { justify-content: center; }
      .hero-proof { justify-content: center; }
    }

    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(28,123,227,0.1); color: var(--app-blue);
      padding: 6px 14px; border-radius: var(--radius-pill);
      font-size: 12px; font-weight: 700; letter-spacing: 0.06em;
      text-transform: uppercase; margin-bottom: 20px;
    }

    .hero-headline { margin-bottom: 20px; color: var(--text-primary); }
    .hero-headline em { font-style: normal; color: var(--app-blue); }

    .hero-sub { color: var(--text-secondary); margin-bottom: 36px; max-width: 500px; }
    @media(max-width:900px) { .hero-sub { margin-left: auto; margin-right: auto; } }

    .hero-actions { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 40px; }

    .hero-proof {
      display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
      font-size: 13px; color: var(--text-secondary);
    }
    .proof-item { display: flex; align-items: center; gap: 6px; }
    .proof-check { color: var(--app-green); font-weight: 700; }
    .proof-stars { color: var(--app-yellow); letter-spacing: 1px; }

    /* ─── PHONE DEVICE FRAME ─── */
    .phone-outer {
      display: inline-block; position: relative;
      filter: drop-shadow(0 30px 60px rgba(0,0,0,0.22)) drop-shadow(0 8px 16px rgba(0,0,0,0.12));
      animation: float 5s ease-in-out infinite;
    }
    @keyframes float {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-14px); }
    }
    .phone-frame {
      background: #1A1A1A;
      border-radius: 48px;
      padding: 13px;
      position: relative;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);
    }
    .phone-notch {
      position: absolute; top: 13px; left: 50%; transform: translateX(-50%);
      width: 86px; height: 24px;
      background: #1A1A1A; border-radius: 0 0 16px 16px; z-index: 10;
    }
    .phone-screenshot { width: 300px; border-radius: 36px; display: block; }

    /* Floating call-out badges */
    .float-badge {
      position: absolute;
      background: white;
      border-radius: var(--radius-sm);
      padding: 10px 14px;
      box-shadow: var(--shadow-card);
      font-size: 13px; font-weight: 700;
      white-space: nowrap;
      display: flex; align-items: center; gap: 8px;
      border: 1px solid rgba(0,0,0,0.06);
    }
    .badge-l  { left: -120px; animation: badge-sway 4s ease-in-out infinite; }
    .badge-r  { right: -120px; animation: badge-sway 4.5s ease-in-out infinite 0.6s; }
    .badge-b  { left: -100px; animation: badge-sway 3.8s ease-in-out infinite 1.2s; }
    @keyframes badge-sway {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .badge-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

    /* ─── SECTION HEADERS ─── */
    .section-hd { text-align: center; margin-bottom: 64px; }
    .section-label {
      display: inline-block; color: var(--app-blue);
      font-size: 12px; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; margin-bottom: 12px;
    }

    /* ─── STATS BAR ─── */
    #stats {
      padding: 56px 0;
      background: var(--app-blue);
    }
    .stats-row {
      display: grid; grid-template-columns: repeat(4,1fr);
      gap: 0; text-align: center;
    }
    @media(max-width:700px) { .stats-row { grid-template-columns: repeat(2,1fr); gap: 24px; } }
    .stat-item { padding: 8px 20px; }
    .stat-item + .stat-item { border-left: 1px solid rgba(255,255,255,0.2); }
    @media(max-width:700px) { .stat-item + .stat-item { border-left: none; } }
    .stat-num {
      font-size: clamp(36px,5vw,56px); font-weight: 800;
      letter-spacing: -0.03em; color: white; line-height: 1;
      margin-bottom: 6px;
    }
    .stat-label { font-size: 13px; color: rgba(255,255,255,0.75); line-height: 1.4; font-weight: 500; }

    /* ─── BEFORE / AFTER ─── */
    .ba-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 3px;
      border-radius: var(--radius); overflow: hidden;
      margin-top: 56px; box-shadow: var(--shadow-card);
    }
    @media(max-width:700px) { .ba-grid { grid-template-columns: 1fr; } }
    .ba-before { background: #FFF5F5; padding: 40px 36px; }
    .ba-after  { background: #F0FFF4; padding: 40px 36px; }
    .ba-col-label {
      font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; margin-bottom: 24px; opacity: 0.5;
    }
    .ba-row {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 12px 0; border-bottom: 1px solid rgba(0,0,0,0.05);
      font-size: 15px; line-height: 1.5;
    }
    .ba-row:last-child { border-bottom: none; }
    .ba-icon-bad  { color: #FF3B30; font-size: 16px; flex-shrink: 0; margin-top: 2px; }
    .ba-icon-good { color: var(--app-green); font-size: 16px; flex-shrink: 0; margin-top: 2px; }

    /* ─── HOW IT WORKS — card style from app ─── */
    .steps-row {
      display: grid; grid-template-columns: repeat(4,1fr); gap: 24px;
      margin-top: 56px;
    }
    @media(max-width:900px) { .steps-row { grid-template-columns: repeat(2,1fr); } }
    @media(max-width:500px) { .steps-row { grid-template-columns: 1fr; } }
    .step-card {
      background: white; border-radius: var(--radius);
      box-shadow: var(--shadow-card); padding: 28px 24px;
      text-align: center; position: relative;
      border: 1px solid rgba(0,0,0,0.04);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .step-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-strong); }
    .step-num {
      width: 44px; height: 44px; background: var(--app-blue);
      color: white; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 18px; margin: 0 auto 18px;
    }
    .step-emoji { font-size: 40px; margin-bottom: 14px; display: block; }
    .step-title { font-size: 17px; font-weight: 700; margin-bottom: 10px; }
    .step-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.6; }

    /* ─── APP PREVIEW SECTION ─── */
    #app-preview { background: var(--bg-light); }
    .preview-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
    }
    @media(max-width:900px) {
      .preview-grid { grid-template-columns: 1fr; }
      .preview-phone { display: flex; justify-content: center; }
    }
    .feature-callout {
      display: flex; align-items: flex-start; gap: 14px;
      padding: 18px 20px; background: white;
      border-radius: var(--radius-sm); box-shadow: var(--shadow-card);
      border: 1px solid rgba(0,0,0,0.04); margin-bottom: 14px;
      transition: transform 0.2s;
    }
    .feature-callout:hover { transform: translateX(4px); }
    .fc-icon {
      width: 44px; height: 44px; border-radius: var(--radius-xs);
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; flex-shrink: 0;
    }
    .fc-title { font-size: 15px; font-weight: 700; margin-bottom: 4px; }
    .fc-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }

    /* ─── 5 BEHAVIORS — mirrors app card style ─── */
    #behaviors { background: white; }
    .behaviors-row {
      display: grid; grid-template-columns: repeat(5,1fr); gap: 16px;
      margin-top: 56px;
    }
    @media(max-width:900px) { .behaviors-row { grid-template-columns: repeat(3,1fr); } }
    @media(max-width:500px) { .behaviors-row { grid-template-columns: repeat(2,1fr); } }
    .behavior-card {
      background: white; border-radius: var(--radius);
      box-shadow: var(--shadow-card); padding: 28px 16px;
      text-align: center; border: 1px solid rgba(0,0,0,0.04);
      transition: transform 0.2s;
    }
    .behavior-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-strong); }
    .beh-emoji { font-size: 40px; margin-bottom: 12px; display: block; }
    .beh-label { font-size: 16px; font-weight: 800; margin-bottom: 8px; }
    .beh-desc { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }

    /* ─── FEATURES GRID ─── */
    #features { background: var(--bg-light); }
    .features-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 20px;
      margin-top: 56px;
    }
    @media(max-width:900px) { .features-grid { grid-template-columns: repeat(2,1fr); } }
    @media(max-width:500px) { .features-grid { grid-template-columns: 1fr; } }
    .feat-card {
      background: white; border-radius: var(--radius);
      box-shadow: var(--shadow-card); padding: 28px 24px;
      border: 1px solid rgba(0,0,0,0.04);
      transition: transform 0.2s;
    }
    .feat-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-strong); }
    .feat-card.wide { grid-column: span 2; }
    @media(max-width:500px) { .feat-card.wide { grid-column: span 1; } }
    .feat-icon {
      width: 50px; height: 50px; border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 22px; margin-bottom: 16px;
    }
    .feat-title { font-size: 18px; font-weight: 700; margin-bottom: 10px; }
    .feat-desc { font-size: 14px; color: var(--text-secondary); line-height: 1.65; }
    .feat-tag {
      display: inline-block; margin-top: 14px;
      background: rgba(28,123,227,0.1); color: var(--app-blue);
      padding: 4px 12px; border-radius: var(--radius-pill);
      font-size: 12px; font-weight: 700;
    }

    /* ─── TESTIMONIALS ─── */
    #testimonials { background: white; }
    .testi-grid {
      display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-top: 56px;
    }
    @media(max-width:900px) { .testi-grid { grid-template-columns: 1fr; max-width: 500px; margin-left:auto; margin-right:auto; } }
    .testi-card {
      background: white; border-radius: var(--radius);
      box-shadow: var(--shadow-card); padding: 28px;
      border: 1px solid rgba(0,0,0,0.04); position: relative;
    }
    .testi-card.featured {
      background: #EBF5FF; border-color: rgba(28,123,227,0.2);
      box-shadow: 0 8px 32px rgba(28,123,227,0.15);
    }
    .testi-stars { color: var(--app-yellow); font-size: 14px; margin-bottom: 14px; letter-spacing: 2px; }
    .testi-text { font-size: 15px; line-height: 1.7; margin-bottom: 20px; color: var(--text-primary); }
    .testi-author { display: flex; align-items: center; gap: 12px; }
    .testi-avatar {
      width: 40px; height: 40px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .testi-name { font-size: 14px; font-weight: 700; }
    .testi-role { font-size: 12px; color: var(--text-secondary); }

    /* ─── COMPARISON TABLE ─── */
    #compare { background: var(--bg-light); }
    .compare-wrap { overflow-x: auto; margin-top: 56px; border-radius: var(--radius); box-shadow: var(--shadow-card); }
    .compare-table {
      width: 100%; border-collapse: collapse; min-width: 680px;
      background: white; border-radius: var(--radius); overflow: hidden;
    }
    .compare-table th {
      padding: 18px 20px; font-size: 15px; font-weight: 700;
      text-align: center; background: var(--bg-light);
      border-bottom: 2px solid rgba(0,0,0,0.06);
    }
    .compare-table th:first-child { text-align: left; }
    .compare-table th.kudosy-th {
      background: var(--app-blue); color: white;
    }
    .compare-table td {
      padding: 14px 20px; border-bottom: 1px solid rgba(0,0,0,0.05);
      font-size: 14px; text-align: center; vertical-align: middle;
    }
    .compare-table td:first-child { text-align: left; font-weight: 600; color: var(--text-primary); }
    .compare-table td.kudosy-td {
      background: rgba(28,123,227,0.05); font-weight: 700; color: var(--app-blue);
      border-left: 2px solid rgba(28,123,227,0.2); border-right: 2px solid rgba(28,123,227,0.2);
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .cmp-check { color: var(--app-green); font-size: 18px; font-weight: 700; }
    .cmp-cross { color: #C7C7CC; font-size: 18px; }
    .cmp-warn  { color: var(--app-orange); font-size: 15px; }
    .best-badge {
