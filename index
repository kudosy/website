<script>
  // ─── SCROLL REVEAL ───
  const ro = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting) { e.target.classList.add('up'); ro.unobserve(e.target); } });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach(el => ro.observe(el));

  // ─── COUNTER ───
  const co = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if(e.isIntersecting) {
        const t = parseInt(e.target.getAttribute('data-count'));
        let n = 0; const step = t/50;
        const i = setInterval(() => {
          n = Math.min(n+step, t);
          e.target.innerHTML = Math.round(n) + '<span>%</span>';
          if(n >= t) clearInterval(i);
        }, 30);
        co.unobserve(e.target);
      }
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('[data-count]').forEach(el => co.observe(el));

  // ─── FAQ ───
  document.querySelectorAll('.faq-q').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement;
      const open = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
      if(!open) item.classList.add('open');
    });
  });
</script>
